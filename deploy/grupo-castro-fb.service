[Unit]
Description=Grupo Castro - F&B Demo API
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/grupo-castro-fb
ExecStart=/opt/grupo-castro-fb/venv/bin/uvicorn backend.app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
